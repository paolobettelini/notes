%%%%% \begin{snippettheorem} and such. These enviroments inject stellar commands in the PDF.

\NewDocumentEnvironment{snippettheorem}{m m o}
{\begin{snippet}{#1}[\metastring{type}{Theorem}\IfNoValueF{#3}{#3}]
\begin{stheorem}{#2}}
{\end{stheorem}
\end{snippet}}

