%%%%%%%%%% Stellar commands utils %%%%%%%%%%

\ExplSyntaxOn
\DeclareDocumentCommand{\snippetref}{d[] d[]}{%
    \IfNoValueTF { #2 }
    { \href{/snippet/#1}{#1} }
    { \href{/snippet/#1}{#2} }
}
\ExplSyntaxOff

\ExplSyntaxOn
\DeclareDocumentCommand{\labelref}{d[] d[]}{%
    \href{|#1}{#2}
}
\ExplSyntaxOff

\newcommand{\beginnewline}{%
    \ifthenelse{\boolean{@twocolumn}}{%
        \if@firstcolumn\else\par\fi%
    }{%
        \if@nobreak\else\par\fi%
    }%
}

% Command to break lines before and after the content.
% Used for every PDF command. The zero-width box keeps the command on one
% unbreakable line while allowing it to extend beyond the page boundary.
\newcommand{\@padcmd}[1]{%
\begingroup
\hbadness=10000
\beginnewline~\\
\makebox[0pt][l]{#1}%
\beginnewline~\\
\par
\endgroup
}

\renewcommand{\section}[1]{\@padcmd{!section #1}}
\renewcommand{\subsection}[1]{\@padcmd{!subsection #1}}
\renewcommand{\subsubsection}[1]{\@padcmd{!subsubsection #1}}
\newcommand{\genpage}{\@padcmd{!gen-page true}}
\newcommand{\id}[1]{\@padcmd{!id #1}}

% Capture plain HTML with verbatim catcodes, then emit it as one unbreakable
% Stellar command. Source line breaks become spaces in the generated command.
\ExplSyntaxOn

\tl_new:N \l__stellar_plainhtml_tl
\bool_new:N \l__stellar_plainhtml_first_line_bool

\cs_new_protected:Npn \__stellar_plainhtml_process_line:
  {
    \bool_if:NTF \l__stellar_plainhtml_first_line_bool
      { \bool_set_false:N \l__stellar_plainhtml_first_line_bool }
      { \tl_put_right:Nn \l__stellar_plainhtml_tl { ~ } }

    \tl_put_right:Nx \l__stellar_plainhtml_tl
      { \exp_not:o { \the\verbatim@line } }
  }

\cs_new_protected:Npn \__stellar_plainhtml_begin:
  {
    \begingroup
    \tl_set:Nn \l__stellar_plainhtml_tl { !plain~ }
    \bool_set_true:N \l__stellar_plainhtml_first_line_bool
    \cs_set_eq:NN \verbatim@processline \__stellar_plainhtml_process_line:
    \@verbatim
    \frenchspacing
    \@vobeyspaces
    \verbatim@start
  }

\cs_new_protected:Npn \__stellar_plainhtml_end:
  {
    \endtrivlist
    \exp_args:NV \@padcmd \l__stellar_plainhtml_tl
    \endgroup
    \@doendpe
  }

\NewDocumentEnvironment{plainhtml}{}
  { \__stellar_plainhtml_begin: }
  { \__stellar_plainhtml_end: }

\ExplSyntaxOff

% Include snippet command
% Usage: \includesnpt{id}
%        \includesnpt[key1=val1,key2=val2,key3=val3]{id}
%        \includesnpt[key={value,with,commas}]{id}
\ExplSyntaxOn

\tl_new:N \l__includesnpt_params_tl
\tl_new:N \l__includesnpt_cmd_tl

\cs_new_protected:Npn \__includesnpt_pad:nn #1 #2
  {
    \tl_set:Nn \l__includesnpt_cmd_tl { !include~#2 }

    \tl_if_blank:nF { #1 }
      {
        \tl_put_right:Nn \l__includesnpt_cmd_tl { ~#1 }
      }

    \exp_args:NV \@padcmd \l__includesnpt_cmd_tl
  }

\cs_generate_variant:Nn \__includesnpt_pad:nn { Vn }

\NewDocumentCommand{\includesnpt}{O{} m}
  {
    \tl_clear:N \l__includesnpt_params_tl

    \clist_map_inline:nn { #1 }
      {
        \tl_if_empty:NF \l__includesnpt_params_tl
          { \tl_put_right:Nn \l__includesnpt_params_tl { \& } }

        \tl_put_right:Nn \l__includesnpt_params_tl { ##1 }
      }

    \__includesnpt_pad:Vn \l__includesnpt_params_tl { #2 }
  }

\ExplSyntaxOff

% Metadata fragments. Stellar merges consecutive JSON objects from left to
% right, so user-provided fields can override environment defaults.
\ExplSyntaxOn

\bool_new:N \l__stellar_meta_first_bool

\cs_new:Npn \__stellar_meta_string:nn #1 #2
  { \{ "\tl_to_str:n { #1 }" : "\tl_to_str:n { #2 }" \} ~ }

\cs_new:Npn \__stellar_meta_scalar:nn #1 #2
  { \{ "\tl_to_str:n { #1 }" : \tl_to_str:n { #2 } \} ~ }

\cs_new_protected:Npn \__stellar_meta_list:nn #1 #2
  {
    \{ "\tl_to_str:n { #1 }" : [
      \bool_set_true:N \l__stellar_meta_first_bool
      \clist_map_inline:nn { #2 }
        {
          \bool_if:NTF \l__stellar_meta_first_bool
            { \bool_set_false:N \l__stellar_meta_first_bool }
            { , }
          "\tl_to_str:n { ##1 }"
        }
    ] \} ~
  }

\NewDocumentCommand{\metastring}{m m}
  { \__stellar_meta_string:nn { #1 } { #2 } }

\NewDocumentCommand{\metanumber}{m m}
  { \__stellar_meta_scalar:nn { #1 } { #2 } }

\NewDocumentCommand{\metabool}{m m}
  { \__stellar_meta_scalar:nn { #1 } { #2 } }

\NewDocumentCommand{\metalist}{m m}
  { \__stellar_meta_list:nn { #1 } { #2 } }

% The argument must contain one complete JSON object, including its braces.
\NewDocumentCommand{\metajson}{m}
  { \tl_to_str:n { #1 } ~ }

\NewDocumentCommand{\generalizations}{m}
  { \__stellar_meta_list:nn { generalizations } { #1 } }

\ExplSyntaxOff

% Snippet enviroment
\NewDocumentEnvironment{snippet}{m o}
{\@padcmd{!snippet #1 \IfNoValueF{#2}{#2}}}
{\@padcmd{!endsnippet}}

% Command to put the QED symbol
\newcommand{\@qedsymbol}{\(\labelref["Quod erat demonstrandum!"][\color{black}{\blacksquare}]\)}
\newcommand{\@qed}{%
    \ifhmode \unskip\nobreak\hfil\penalty50\hskip1em\null\hfill\@qedsymbol%
    \else \leavevmode\hbox{}\nobreak\hfill\@qedsymbol%
    \fi%
}

%%%%%%%%%% Colored sentences commands %%%%%%%%%%
% Adapted from
% https://github.com/SeniorMars/dotfiles/blob/master/latex_template/preamble.tex

\newcommand{\customsentence}[4]{%
    \newtcbtheorem{#1}{#2}%
    {%
        theorem name, %this removes the number
        enhanced,
        breakable,
        colback = #3,
        frame hidden,
        boxrule = 0sp,
        borderline west = {2pt}{0pt}{#4},
        sharp corners,
        detach title,
        before upper = \tcbtitle\par\smallskip,
        coltitle = #4,
        fonttitle = \bfseries\sffamily,
        description font = \mdseries,
        separator sign none,
        segmentation style={solid, #4},
    }%
    {th}%
}

