// Stellar definition commands for Typst
// Faithful port of definitions.sty (2023/01/01)
// Target: Typst 0.15.x
//
// Text commands follow this calling convention:
//   #category()                         -> default text
//   #category(text: [categories])       -> replacement text
//   #category(text: [open], link-label: "Open")
//
// The LaTeX command \set conflicts with Typst's #set keyword and is therefore
// exported as #set-term(). All other source names are kept where practical.
// Nullary math commands such as catob, cathom, sin, det, and expectation
// are content values, not functions. Write `$catob (cal(C))$`, preserving a
// space before the ordinary parenthesized expression.

#import "stellar.typ" as _stellar

#let _text-ref(identifier, label, default, text: none, link-label: none) = {
  let shown = if text == none { default } else { text }
  let effective-label = if link-label == none { label } else { link-label }
  _stellar.snippetref(identifier + "|" + effective-label, body: shown)
}

#let _black(body) = text(fill: black, body)

#let _math-ref(identifier, label, body, class: none, operator: false) = {
  let linked = _stellar.snippetref(identifier + "|" + label, body: _black(body))
  if operator {
    math.op(linked)
  } else if class != none {
    math.class(class, linked)
  } else {
    linked
  }
}

#let _label-math(label, body, class: none, operator: false) = {
  let linked = _stellar.labelref(label, _black(body))
  if operator {
    math.op(linked)
  } else if class != none {
    math.class(class, linked)
  } else {
    linked
  }
}

#let _append(head, tail) = if tail == none { head } else { [#head#tail] }

#let _subscripted(head, subscript: none, tail: none) = {
  let decorated = if subscript == none {
    head
  } else {
    math.attach(head, b: subscript)
  }
  if tail == none { decorated } else { [#decorated#tail] }
}

// Generic escape hatches, useful for commands not yet given a named wrapper.
#let textref(identifier, label, default, text: none, link-label: none) = {
  _text-ref(identifier, label, default, text: text, link-label: link-label)
}
#let mathref(identifier, label, body, class: none, operator: false) = {
  _math-ref(identifier, label, body, class: class, operator: operator)
}

